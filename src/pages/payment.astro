---
import FlowLayout from '../layouts/FlowLayout.astro';
---

<FlowLayout title="Payment" description="Complete your payment - Logan Health">
  <Fragment slot="head">
    <style is:inline>
        .payment-page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .payment-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--spacing-8) var(--spacing-4);
        }

        .payment-card {
            max-width: 480px;
            width: 100%;
            background: var(--color-white);
            border-radius: var(--radius-2xl);
            padding: var(--spacing-10);
            box-shadow: var(--shadow-xl);
            text-align: center;
        }

        .redirect-spinner {
            width: 48px;
            height: 48px;
            border: 4px solid var(--color-border);
            border-top-color: var(--color-primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto var(--spacing-6);
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .redirect-title {
            font-size: var(--font-size-xl);
            font-weight: 700;
            color: var(--color-text);
            margin-bottom: var(--spacing-2);
        }

        .redirect-subtitle {
            font-size: var(--font-size-base);
            color: var(--color-text-light);
            margin-bottom: var(--spacing-2);
            line-height: 1.6;
        }

        .redirect-product {
            font-weight: 600;
            color: var(--color-primary);
        }

        .redirect-price {
            font-size: var(--font-size-2xl);
            font-weight: 800;
            color: var(--color-primary);
            margin: var(--spacing-4) 0;
        }

        .redirect-customer {
            font-size: var(--font-size-sm);
            color: var(--color-text-light);
            margin-bottom: var(--spacing-6);
        }

        #payment-error {
            display: none;
            background: var(--color-error-light);
            color: var(--color-error);
            padding: var(--spacing-4);
            border-radius: var(--radius-lg);
            font-size: var(--font-size-sm);
            margin-bottom: var(--spacing-4);
        }

        #retry-button {
            display: none;
            margin-top: var(--spacing-4);
        }

        .secure-note {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: var(--spacing-2);
            margin-top: var(--spacing-6);
            font-size: var(--font-size-sm);
            color: var(--color-text-lighter);
        }

        .secure-note svg {
            width: 14px;
            height: 14px;
        }

        #missing-info {
            display: none;
            text-align: center;
        }

        .missing-info-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto var(--spacing-4);
            background: var(--color-error-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-error);
        }

        .missing-info-icon svg {
            width: 32px;
            height: 32px;
        }

        .missing-info-title {
            font-size: var(--font-size-xl);
            font-weight: 700;
            color: var(--color-text);
            margin-bottom: var(--spacing-2);
        }

        .missing-info-message {
            font-size: var(--font-size-base);
            color: var(--color-text-light);
            margin-bottom: var(--spacing-6);
            line-height: 1.6;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: var(--spacing-2);
            margin-top: var(--spacing-6);
            font-size: var(--font-size-sm);
            color: var(--color-text-light);
            text-decoration: none;
            transition: color var(--transition-base);
        }

        .back-link:hover {
            color: var(--color-primary);
        }

        .back-link svg {
            width: 16px;
            height: 16px;
        }

        @media (max-width: 640px) {
            .payment-card {
                padding: var(--spacing-6);
                margin: var(--spacing-4);
            }
        }
    </style>
  </Fragment>

  <!-- Content -->
  <main class="payment-content">
      <div class="payment-card">

          <!-- Missing info error state -->
          <div id="missing-info">
              <div class="missing-info-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <line x1="12" y1="8" x2="12" y2="12"/>
                      <line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
              </div>
              <h2 class="missing-info-title">Missing Information</h2>
              <p class="missing-info-message">We couldn't find your details. Please go back to the questionnaire to start your order.</p>
              <a href="/#questionnaire" class="btn btn-primary" style="width: 100%;">Go to Questionnaire</a>
          </div>

          <!-- Redirect / loading state -->
          <div id="payment-content">
              <div id="payment-loading">
                  <div class="redirect-spinner"></div>
                  <h2 class="redirect-title">Redirecting to Secure Checkout</h2>
                  <p class="redirect-subtitle">
                      <span class="redirect-product" id="product-name"></span>
                  </p>
                  <p class="redirect-price" id="product-price"></p>
                  <p class="redirect-customer">for <span id="customer-name"></span></p>
              </div>

              <div id="payment-error" role="alert"></div>

              <a href="/#questionnaire" class="btn btn-primary" id="retry-button" style="width: 100%;">
                  Try Again
              </a>

              <div class="secure-note">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                  <span>Secure payment — you'll be redirected to complete your payment</span>
              </div>
          </div>

          <a href="/" class="back-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="19" y1="12" x2="5" y2="12"/>
                  <polyline points="12,19 5,12 12,5"/>
              </svg>
              Back to homepage
          </a>
      </div>
  </main>

  <Fragment slot="scripts">
    <!-- Payment logic -->
    <script is:inline src="/js/payment.js"></script>
  </Fragment>
</FlowLayout>
