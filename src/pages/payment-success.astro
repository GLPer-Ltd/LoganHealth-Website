---
import FlowLayout from '../layouts/FlowLayout.astro';
---

<FlowLayout title="Payment Confirmed" description="Payment confirmed - Logan Health">
  <Fragment slot="head">
    <style is:inline>
        .success-page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .success-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--spacing-8) var(--spacing-4);
        }

        .success-card {
            max-width: 560px;
            text-align: center;
            background: var(--color-white);
            border-radius: var(--radius-2xl);
            padding: var(--spacing-10);
            box-shadow: var(--shadow-xl);
        }

        .success-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto var(--spacing-6);
            background: var(--color-success-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-success);
        }

        .success-icon svg {
            width: 40px;
            height: 40px;
        }

        .success-title {
            font-size: var(--font-size-3xl);
            font-weight: 700;
            color: var(--color-text);
            margin-bottom: var(--spacing-4);
        }

        .success-message {
            font-size: var(--font-size-lg);
            color: var(--color-text-light);
            margin-bottom: var(--spacing-8);
            line-height: 1.7;
        }

        .next-steps {
            background: var(--color-bg-alt);
            border-radius: var(--radius-xl);
            padding: var(--spacing-6);
            text-align: left;
            margin-bottom: var(--spacing-8);
        }

        .next-steps h3 {
            font-size: var(--font-size-lg);
            font-weight: 600;
            margin-bottom: var(--spacing-4);
            color: var(--color-text);
        }

        .next-steps ol {
            list-style: none;
            padding: 0;
            margin: 0;
            counter-reset: steps;
        }

        .next-steps li {
            display: flex;
            align-items: flex-start;
            gap: var(--spacing-3);
            margin-bottom: var(--spacing-3);
            color: var(--color-text);
            font-size: var(--font-size-base);
        }

        .next-steps li:last-child {
            margin-bottom: 0;
        }

        .step-number {
            flex-shrink: 0;
            width: 24px;
            height: 24px;
            background: var(--color-primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: var(--font-size-sm);
            font-weight: 600;
        }

        .expiry-note {
            display: flex;
            align-items: flex-start;
            gap: var(--spacing-3);
            background: var(--color-warning-light);
            border-left: 4px solid var(--color-warning);
            padding: var(--spacing-4);
            border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
            margin-bottom: var(--spacing-8);
            text-align: left;
        }

        .expiry-note svg {
            flex-shrink: 0;
            width: 20px;
            height: 20px;
            color: var(--color-warning);
            margin-top: 2px;
        }

        .expiry-note p {
            margin: 0;
            font-size: var(--font-size-sm);
            color: #92400E;
        }

        .success-actions {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-3);
        }

        .success-actions .btn {
            width: 100%;
        }

        .help-text {
            margin-top: var(--spacing-6);
            font-size: var(--font-size-sm);
            color: var(--color-text-light);
        }

        .help-text a {
            color: var(--color-primary);
        }

        @media (max-width: 640px) {
            .success-card {
                padding: var(--spacing-6);
                margin: var(--spacing-4);
            }

            .success-title {
                font-size: var(--font-size-2xl);
            }
        }
    </style>
  </Fragment>

  <!-- Content -->
  <main class="success-content">
      <div class="success-card">
          <div class="success-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
              </svg>
          </div>

          <h1 class="success-title">Payment Confirmed!</h1>
          <p class="success-message">Thank you for your payment. We've sent you an email with a link to book your consultation.</p>

          <div class="next-steps">
              <h3>What happens next?</h3>
              <ol>
                  <li>
                      <span class="step-number">1</span>
                      <span>Check your email inbox (and spam folder)</span>
                  </li>
                  <li>
                      <span class="step-number">2</span>
                      <span>Click the booking link in the email</span>
                  </li>
                  <li>
                      <span class="step-number">3</span>
                      <span>Choose a convenient time for your consultation</span>
                  </li>
              </ol>
          </div>

          <div class="expiry-note">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12,6 12,12 16,14"/>
              </svg>
              <p><strong>Important:</strong> Your booking link expires in 72 hours. Please book your consultation before then.</p>
          </div>

          <div class="success-actions">
              <a href="/" class="btn btn-primary">Return to Homepage</a>
          </div>

          <p class="help-text">
              Didn't receive the email? Check your spam folder or <a href="mailto:bookings@loganhealth.co.uk">contact us</a> for help.
          </p>
      </div>
  </main>

  <Fragment slot="scripts">
    <script is:inline>
    (function() {
        var WORKER_URL = 'https://loganhealth-payments.misty-heart-ac54.workers.dev';
        var params = new URLSearchParams(window.location.search);
        var sessionId = params.get('session_id');

        if (sessionId) {
            fetch(WORKER_URL + '/api/payment-status?session_id=' + encodeURIComponent(sessionId))
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.status === 'paid') {
                        // Payment confirmed — page already shows success state
                        return;
                    }
                    // If pending, the webhook may still be processing — show a note
                    var msg = document.querySelector('.success-message');
                    if (msg && data.status === 'pending') {
                        msg.textContent = 'Your payment is being processed. You should receive your booking email shortly.';
                    }
                })
                .catch(function() {
                    // Silently fail — the success page is already showing
                });
        }
    })();
    </script>
  </Fragment>
</FlowLayout>
