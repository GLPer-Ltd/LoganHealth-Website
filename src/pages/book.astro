---
import FlowLayout from '../layouts/FlowLayout.astro';
---

<FlowLayout title="Book Your Consultation" description="Book your GLP-1 consultation with Logan Health" showFooter={true}>
  <Fragment slot="head">
    <!-- Calendly CSS -->
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">

    <style is:inline>
        * { box-sizing: border-box; }

        .booking-page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background: var(--color-bg-alt);
        }

        /* Hero banner */
        .booking-hero {
            background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
            padding: var(--spacing-6) var(--spacing-4);
            text-align: center;
            color: white;
        }

        .booking-hero h1 {
            font-size: var(--font-size-2xl);
            font-weight: 700;
            color: white;
            margin: 0 0 var(--spacing-1) 0;
        }

        .booking-hero p {
            font-size: var(--font-size-base);
            opacity: 0.9;
            margin: 0;
        }

        .booking-hero .trust-badges {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: var(--spacing-6);
            margin-top: var(--spacing-4);
            opacity: 0.85;
            font-size: var(--font-size-sm);
        }

        .booking-hero .trust-badge {
            display: flex;
            align-items: center;
            gap: var(--spacing-2);
        }

        .booking-hero .trust-badge svg {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
        }

        /* Main content */
        .booking-main {
            flex: 1;
            padding: var(--spacing-8) var(--spacing-4);
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
        }

        /* States */
        .booking-loading,
        .booking-error,
        .booking-success {
            display: none;
        }

        .booking-loading.active,
        .booking-error.active,
        .booking-success.active {
            display: block;
        }

        /* Loading */
        .booking-loading {
            text-align: center;
            padding: var(--spacing-16) var(--spacing-4);
        }

        .booking-loading .spinner {
            width: 48px;
            height: 48px;
            border: 4px solid var(--color-border);
            border-top-color: var(--color-primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto var(--spacing-6);
        }

        .booking-loading p {
            color: var(--color-text-light);
            font-size: var(--font-size-lg);
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Error */
        .booking-error {
            text-align: center;
            padding: var(--spacing-12) var(--spacing-4);
            max-width: 500px;
            margin: 0 auto;
        }

        .booking-error .error-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto var(--spacing-6);
            background: var(--color-warning-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-warning);
        }

        .booking-error .error-icon svg {
            width: 40px;
            height: 40px;
        }

        .booking-error h2 {
            font-size: var(--font-size-2xl);
            color: var(--color-text);
            margin-bottom: var(--spacing-4);
        }

        .booking-error p {
            color: var(--color-text-light);
            margin-bottom: var(--spacing-6);
            line-height: 1.6;
        }

        .booking-error .error-actions {
            display: flex;
            gap: var(--spacing-4);
            justify-content: center;
            flex-wrap: wrap;
        }

        /* Calendly widget — full width, generous height to avoid internal scrolling */
        .calendly-inline-widget {
            min-width: 320px;
            height: 950px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .booking-hero {
                padding: var(--spacing-8) var(--spacing-4);
            }

            .booking-hero h1 {
                font-size: var(--font-size-2xl);
            }

            .booking-hero .trust-badges {
                flex-direction: column;
                gap: var(--spacing-3);
            }

            .booking-main {
                padding: var(--spacing-4);
            }

            .calendly-inline-widget {
                height: 1050px;
            }
        }

        @media (max-width: 480px) {
            .calendly-inline-widget {
                height: 1150px;
            }
        }
    </style>
  </Fragment>

  <!-- Loading State -->
  <div class="booking-loading active" id="bookingLoading">
      <div class="spinner"></div>
      <p>Preparing your booking...</p>
  </div>

  <!-- Error State -->
  <div class="booking-error" id="bookingError">
      <div class="error-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
      </div>
      <h2>Booking Link Invalid</h2>
      <p>This booking link has expired or has already been used. Each link can only be used once and expires after 72 hours.</p>
      <div class="error-actions">
          <a href="/" class="btn btn-primary">Return to Homepage</a>
          <a href="mailto:bookings@loganhealth.co.uk" class="btn btn-outline">Contact Us</a>
      </div>
  </div>

  <!-- Success State -->
  <div class="booking-success" id="bookingSuccess">
      <!-- Hero -->
      <div class="booking-hero">
          <h1>Book Your Consultation</h1>
          <p id="welcomeMessage">Select a convenient time for your consultation with our pharmacist.</p>
          <div class="trust-badges">
              <span class="trust-badge">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                  Fully qualified pharmacists
              </span>
              <span class="trust-badge">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                  </svg>
                  30-minute consultation
              </span>
              <span class="trust-badge">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15 10l-4 4l-2-2"/>
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                      <line x1="16" y1="2" x2="16" y2="6"/>
                      <line x1="8" y1="2" x2="8" y2="6"/>
                      <line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                  Book at a time that suits you
              </span>
          </div>
      </div>

      <!-- Calendly -->
      <main class="booking-main">
          <div class="calendly-inline-widget" id="calendlyWidget" data-url="https://calendly.com/loganhealth-support/30min"></div>
      </main>
  </div>

  <Fragment slot="scripts">
    <!-- Calendly -->
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>

    <!-- Booking Logic -->
    <script is:inline src="/js/booking.js"></script>
  </Fragment>
</FlowLayout>
